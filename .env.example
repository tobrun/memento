# ── LLM Backend ───────────────────────────────────────────────
# Option A: Gemini (default)
GOOGLE_API_KEY=your-gemini-api-key
# MODEL=gemini-3.1-flash-lite-preview   # default when using Gemini

# Option B: Self-hosted / OpenAI-compatible endpoint
# When OPENAI_API_BASE is set, GOOGLE_API_KEY is not required.
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=not-needed
# MODEL=llama3

# ── Agent Config ───────────────────────────────────────────────
# Directory for per-datasource SQLite databases (one .db file per datasource)
MEMORY_DB=./databases

# Root inbox directory (subdirectories become datasources)
WATCH_DIR=./inbox

# HTTP API + web UI port
PORT=8888

# MCP server port (separate from the main API)
MCP_PORT=8889
